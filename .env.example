# Copy to `.env.local` at the repo root (gitignored). When `web/` exists (task 1.8),
# use the same values in `web/.env.local` for Next.js.

# --- Local (`supabase start` → `supabase status`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-supabase-status>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key-from-supabase-status>

# --- Hosted (Supabase Dashboard → Project Settings → API) ---
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key — server only; never expose to the browser>

# --- CLI / migrations (optional) ---
# SUPABASE_PROJECT_REF=<project-ref>
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Later tasks ---
# MAKE_WEBHOOK_URL=<Make.com scenario webhook for email notifications>

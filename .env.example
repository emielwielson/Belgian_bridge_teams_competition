# Copy to `.env.local` at the repo root (gitignored). When `web/` exists (task 1.8),
# use the same values in `web/.env.local` for Next.js.
#
# Use publishable + secret keys (sb_publishable_... / sb_secret_...), not legacy
# anon / service_role JWT keys. See: https://supabase.com/docs/guides/getting-started/api-keys

# --- Local (`supabase start` → `supabase status`) ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key-from-supabase-status>
SUPABASE_SECRET_KEY=<secret-key-from-supabase-status>

# --- Hosted (Dashboard → Project Settings → API Keys) ---
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
# SUPABASE_SECRET_KEY=<secret-key — server only; never expose to the browser>

# --- CLI / migrations (optional) ---
# SUPABASE_PROJECT_REF=<project-ref>
# DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Later tasks ---
# MAKE_WEBHOOK_URL=<Make.com scenario webhook for email notifications>

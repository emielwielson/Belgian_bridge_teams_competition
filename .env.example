# Copy to `.env` at the repo root (gitignored). For Next.js, copy to `web/.env.local`.
#
# Dashboard → Project Settings → API Keys (publishable + secret only).
# https://supabase.com/docs/guides/getting-started/api-keys

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
# Server only — never expose in the browser or NEXT_PUBLIC_* vars:
SUPABASE_SECRET_KEY=sb_secret_<your-secret-key>

# Optional
# SUPABASE_PROJECT_REF=<project-ref>
# DATABASE_URL=<connection-string>

# Public app URL for links in emails (e.g. postponement approve on match page)
# NEXT_PUBLIC_APP_URL=https://your-app.example.com

# Make.com webhook — sends emails (postponement CC: both captains + competition managers)
# MAKE_WEBHOOK_URL=<make-webhook-url>

# Regional bye VP automation (Make.com / cron → POST /api/cron/award-bye-scores)
# AWARD_BYE_SCORES_SECRET=<random-secret>
